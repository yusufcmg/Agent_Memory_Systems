# .gitattributes file for vendoring rules

# Exclude specific files and directories from language statistics
install.sh linguist-objective-c=false
*.sh linguist-objective-c=false
*.py linguist-objective-c=false
*.js linguist-objective-c=false
*.ts linguist-objective-c=false
*.tsx linguist-objective-c=false
*.jsx linguist-objective-c=false
*.json linguist-objective-c=false

# Mark certain directories to exclude from language statistics
.examples linguist-language=none
.scripts linguist-language=none
.claude linguist-language=none
.claude-code-router linguist-language=none

# Mark all .md files as documentation
*.md linguist-documentation