# ─────────────────────────────────────────────────────────────────
#  .env.example — Copy to .env and fill in your values
#  NEVER commit real secrets. This file is safe to commit.
# ─────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── AI Model API Keys (for Claude Code Router) ────────────────────
# Claude Pro uses browser login (claude → /login), no API key needed.
# Only set ANTHROPIC_API_KEY if you explicitly want direct API access:
# ANTHROPIC_API_KEY=sk-ant-...
#
# OpenRouter (recommended for cheap routine tasks via ccr code):
OPENROUTER_API_KEY=sk-or-...

# ── External Services ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG....
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
